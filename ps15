    // Array of subject marks
    $marks = array(75, 80, 65, 90, 85);

    // Display marks
    echo "<b>Marks:</b> ";
    foreach($marks as $m)
    {
        echo $m . " ";
    }

    echo "<br><br>";

    // Maximum marks
    $max = max($marks);
    echo "Maximum Marks: " . $max . "<br>";

    // Percentage
    $total = array_sum($marks);
    $count = count($marks);
    $percentage = $total / $count;

    echo "Percentage: " . $percentage . "%";
