<!doctype html>
<html>
<head>
    <title>Student Portfolio</title>
</head>
<body>
<h1 align="center">Student Portfolio</h1>

<form>
    <b>Name:</b>
    <input type="text" value="name" name="name"><br><br>
  
    <b>Course:</b>
    <input type="radio" value="dsa" name="course">DSA
    <input type="radio" value="oop" name="course">OOP
    <input type="radio" value="os" name="course">OS<br><br> 

    <b>Hobbies</b>
    <input type="checkbox" value="Gaming" name="hobbies">Gaming
    <input type="checkbox" value="Travelling" name="hobbies">Travelling
    <input type="checkbox" value="Reading" name="hobbies">Reading<br><br>

    <button type="submit" value="submit">Submit</button>
   
</form>


</body>
</html>
