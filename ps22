<!DOCTYPE html>
<html>
<head>
    <title>Simple Quiz</title>

    <style>
        body {
            font-family: Arial;
            background-color: lightblue;
        }
        .box {
            width: 60%;
            margin: auto;
            background: white;
            padding: 20px;
            border: 1px solid gray;
        }
        .btn {
            background-color: purple;
            color: white;
            padding: 10px;
        }
    </style>
</head>

<body>

<div class="box">

<h2 align="center">Simple Quiz</h2>

<form id="quizForm">

<!-- Q1 -->
<p>1. HTML stands for?</p>
<input type="radio" name="q1" value="0"> Hyper Trainer Marking Language<br>
<input type="radio" name="q1" value="1"> Hyper Text Markup Language<br>
<input type="radio" name="q1" value="0"> Hyper Text Marketing Language<br><br>

<!-- Q2 -->
<p>2. CSS is used for?</p>
<input type="radio" name="q2" value="1"> Styling<br>
<input type="radio" name="q2" value="0"> Programming<br>
<input type="radio" name="q2" value="0"> Database<br><br>

<!-- Q3 -->
<p>3. JavaScript is?</p>
<input type="radio" name="q3" value="1"> Scripting Language<br>
<input type="radio" name="q3" value="0"> Database<br>
<input type="radio" name="q3" value="0"> OS<br><br>

<!-- Q4 -->
<p>4. PHP is used for?</p>
<input type="radio" name="q4" value="1"> Server-side scripting<br>
<input type="radio" name="q4" value="0"> Styling<br>
<input type="radio" name="q4" value="0"> Hardware<br><br>

<!-- Q5 -->
<p>5. Which is not a programming language?</p>
<input type="radio" name="q5" value="0"> Java<br>
<input type="radio" name="q5" value="1"> HTML<br>
<input type="radio" name="q5" value="0"> Python<br><br>

<!-- Q6 -->
<p>6. Which tag is used for paragraph?</p>
<input type="radio" name="q6" value="1"> &lt;p&gt;<br>
<input type="radio" name="q6" value="0"> &lt;h1&gt;<br>
<input type="radio" name="q6" value="0"> &lt;div&gt;<br><br>

<!-- Q7 -->
<p>7. Which is a database?</p>
<input type="radio" name="q7" value="1"> MySQL<br>
<input type="radio" name="q7" value="0"> HTML<br>
<input type="radio" name="q7" value="0"> CSS<br><br>

<!-- Q8 -->
<p>8. Bootstrap is?</p>
<input type="radio" name="q8" value="1"> CSS Framework<br>
<input type="radio" name="q8" value="0"> Language<br>
<input type="radio" name="q8" value="0"> Database<br><br>

<!-- Q9 -->
<p>9. JS used for?</p>
<input type="radio" name="q9" value="1"> Interactivity<br>
<input type="radio" name="q9" value="0"> Storage<br>
<input type="radio" name="q9" value="0"> Styling<br><br>

<!-- Q10 -->
<p>10. Which is backend language?</p>
<input type="radio" name="q10" value="1"> PHP<br>
<input type="radio" name="q10" value="0"> HTML<br>
<input type="radio" name="q10" value="0"> CSS<br><br>

<button type="button" class="btn" onclick="submitQuiz()">Submit</button>

</form>

<h3 id="result" align="center"></h3>

</div>

<script>

function submitQuiz()
{
    var score = 0;

    for(var i=1; i<=10; i++)
    {
        var q = document.querySelector('input[name="q'+i+'"]:checked');

        if(q)
        {
            score += parseInt(q.value);
        }
    }

    document.getElementById("result").innerHTML = "Your Score: " + score + "/10";
}

</script>

</body>
</html>
