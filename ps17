if(isset($_POST['submit']))
{
    $name = $_POST['name'];

    // String functions
    $upper = strtoupper($name);
    $length = strlen($name);

    // Array of marks
    $marks = array($_POST['m1'], $_POST['m2'], $_POST['m3']);

    // Total and Average
    $total = array_sum($marks);
    $avg = $total / count($marks);

    echo "<h3>Result:</h3>";
    echo "Name: $upper <br>";
    echo "Name Length: $length <br><br>";

    echo "Total Marks: $total <br>";
    echo "Average Marks: $avg <br>";
