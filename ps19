<?php
if(isset($_POST['submit']))
{
    $str = $_POST['str'];

    echo "<h3>Results:</h3>";

    // a) Uppercase
    echo "Uppercase: " . strtoupper($str) . "<br>";

    // b) Lowercase
    echo "Lowercase: " . strtolower($str) . "<br>";

    // c) First character uppercase
    echo "Ucfirst: " . ucfirst($str) . "<br>";

    // d) First letter of all words uppercase
    echo "Ucwords: " . ucwords($str) . "<br>";

    // e) Remove leading zeroes
    echo "Without Leading Zeroes: " . ltrim($str, "0") . "<br>";

    // f) Reverse
    echo "Reverse: " . strrev($str) . "<br>";

    // Length
    echo "Length: " . strlen($str) . "<br>";

    // Substring (first 5 chars)
    echo "Substring: " . substr($str, 0, 5) . "<br>";
}
